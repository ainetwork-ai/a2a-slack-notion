{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm i -g pnpm@10.33.0 && cd .. && pnpm install --force --reporter=append-only",
  "buildCommand": "cd .. && pnpm --filter slack-a2a build",
  "crons": [
    {
      "path": "/api/cron/cleanup-share-links",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/compact-page-snapshots",
      "schedule": "0 4 * * 0"
    }
  ]
}
