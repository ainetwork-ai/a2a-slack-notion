{
  "manifest_version": 3,
  "name": "Notion Clone Clipper",
  "version": "1.0",
  "description": "Clip web pages to your Notion clone workspace",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  }
}
