generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Auth — WalletConnect + SIWE, JWT-based stateless auth
// ============================================================

model User {
  id            String    @id @default(cuid())
  walletAddress String    @unique @map("wallet_address")
  name          String
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // App relations
  workspaceMembers WorkspaceMember[]
  blocks           Block[]          @relation("CreatedByUser")
  comments         Comment[]
  permissions      PagePermission[]
  notifications    Notification[]
  apiKeys          ApiKey[]
  webhooks         Webhook[]

  @@map("user")
}

// ============================================================
// Workspace
// ============================================================

model Workspace {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       WorkspaceMember[]
  blocks        Block[]
  pageTemplates PageTemplate[]
  automations   Automation[]

  @@map("workspaces")
}

enum WorkspaceRole {
  admin
  member
  guest
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ============================================================
// Block — "Everything is a Block" core model
// ============================================================

enum BlockType {
  page
  text
  heading_1
  heading_2
  heading_3
  bulleted_list
  numbered_list
  to_do
  toggle
  callout
  code
  divider
  image
  quote
  table
  bookmark
  file
  embed
  database

  @@map("block_type")
}

model Block {
  id            String    @id @default(cuid())
  type          BlockType
  parentId      String?   @map("parent_id")
  pageId        String    @map("page_id")
  workspaceId   String    @map("workspace_id")
  properties    Json      @default("{}")
  content       Json      @default("{}")
  childrenOrder String[]  @map("children_order")
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  archived      Boolean   @default(false)

  // Self-relation for block tree
  parent   Block?  @relation("BlockTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Block[] @relation("BlockTree")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("CreatedByUser", fields: [createdBy], references: [id])

  comments      Comment[]
  databaseViews DatabaseView[] @relation("DatabaseViews")
  templates     DatabaseTemplate[] @relation("DatabaseTemplates")

  // Decision #16: Block indexes for query performance
  @@index([pageId, parentId])
  @@index([workspaceId, type])
  @@index([parentId])
  @@map("blocks")
}

// ============================================================
// Database Views — view configurations for database blocks
// ============================================================

enum ViewType {
  table
  board
  list
  calendar
  gallery
  timeline

  @@map("view_type")
}

model DatabaseView {
  id         String   @id @default(cuid())
  databaseId String   @map("database_id")
  name       String
  type       ViewType @default(table)
  filters    Json     @default("{\"logic\":\"and\",\"conditions\":[]}")
  sorts      Json     @default("[]")
  groupBy    Json?
  config     Json     @default("{\"visibleProperties\":[]}")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  database Block @relation("DatabaseViews", fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId, position])
  @@map("database_views")
}

// ============================================================
// Database Templates
// ============================================================

model DatabaseTemplate {
  id          String   @id @default(cuid())
  databaseId  String   @map("database_id")
  name        String
  description String?
  icon        String?
  content     Json     @default("[]")
  values      Json     @default("{}")
  isDefault   Boolean  @default(false) @map("is_default")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  database Block @relation("DatabaseTemplates", fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId, position])
  @@map("database_templates")
}

// ============================================================
// Comments
// ============================================================

model Comment {
  id        String   @id @default(cuid())
  blockId   String   @map("block_id")
  authorId  String   @map("author_id")
  content   Json
  resolved  Boolean  @default(false)
  threadId  String?  @map("thread_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  block   Block     @relation(fields: [blockId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentThread", fields: [threadId], references: [id])
  replies Comment[] @relation("CommentThread")

  @@index([blockId])
  @@map("comments")
}

// ============================================================
// Favorites + Recent Pages
// ============================================================

model Favorite {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  pageId      String   @map("page_id")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, pageId])
  @@index([userId, workspaceId])
  @@map("favorites")
}

model RecentPage {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  pageId      String   @map("page_id")
  visitedAt   DateTime @default(now()) @map("visited_at")

  @@unique([userId, pageId])
  @@index([userId, workspaceId, visitedAt])
  @@map("recent_pages")
}

// ============================================================
// Page Permissions — per-user, per-page access levels
// ============================================================

enum PermissionLevel {
  full_access
  can_edit
  can_comment
  can_view

  @@map("permission_level")
}

model PagePermission {
  id        String          @id @default(cuid())
  pageId    String          @map("page_id")
  userId    String          @map("user_id")
  level     PermissionLevel
  createdAt DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pageId, userId])
  @@index([pageId])
  @@map("page_permissions")
}

// ============================================================
// Notifications
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // mention, comment, page_update
  title     String
  body      String?
  pageId    String?  @map("page_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================================
// Page Snapshots — version history
// ============================================================

model PageSnapshot {
  id        String   @id @default(cuid())
  pageId    String   @map("page_id")
  title     String
  snapshot  Bytes
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([pageId, createdAt])
  @@map("page_snapshots")
}

// ============================================================
// Share Links
// ============================================================

model ShareLink {
  id        String          @id @default(cuid())
  pageId    String          @map("page_id")
  token     String          @unique @default(cuid())
  level     PermissionLevel @default(can_view)
  isPublic  Boolean         @default(false) @map("is_public")
  expiresAt DateTime?       @map("expires_at")
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([pageId])
  @@map("share_links")
}

// ============================================================
// API Keys — for REST API authentication
// ============================================================

model ApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ============================================================
// Webhooks — outbound event delivery to external URLs
// ============================================================

model Webhook {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ============================================================
// Page Templates — reusable page blueprints
// ============================================================

model PageTemplate {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  icon        String?
  category    String   @default("custom")
  content     Json     @default("[]")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, category])
  @@map("page_templates")
}

// ============================================================
// Automations — simple trigger/action rules
// ============================================================

model Automation {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  trigger     Json
  actions     Json
  active      Boolean  @default(true)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("automations")
}
