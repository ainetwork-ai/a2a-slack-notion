# ===========================================
# Notion Clone — Environment Configuration
# ===========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=notion
POSTGRES_PASSWORD=notion_secret_change_me
POSTGRES_DB=notion
DATABASE_URL=postgresql://notion:notion_secret_change_me@localhost:5432/notion

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://:redis_secret_change_me@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me

# ============================================================
# MinIO (S3-compatible object storage)
# ============================================================
MINIO_ROOT_USER=notion_minio
MINIO_ROOT_PASSWORD=minio_secret_change_me
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=notion-files
MINIO_ACCESS_KEY=notion_minio
MINIO_SECRET_KEY=minio_secret_change_me

# ============================================================
# Meilisearch (full-text search)
# ============================================================
MEILI_MASTER_KEY=meili_master_key_change_me_at_least_16_chars
MEILI_HOST=http://localhost:7700
MEILI_URL=http://localhost:7700

# ============================================================
# Auth (JWT / Better Auth)
# ============================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=jwt_secret_change_me_random_32_chars_minimum
AUTH_SECRET=auth_secret_change_me_to_random_32_chars
AUTH_DOMAIN=localhost

# ============================================================
# API Server
# ============================================================
API_PORT=3001
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# ============================================================
# Hocuspocus (Yjs WebSocket server for real-time collab)
# ============================================================
HOCUSPOCUS_PORT=3012

# ============================================================
# Frontend (Next.js)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3012

# ============================================================
# AI (vLLM — OpenAI-compatible inference server)
# ============================================================
VLLM_API_URL=http://localhost:8000/v1
VLLM_MODEL=default

# ============================================================
# Production-only settings
# ============================================================
# Your public domain (used by nginx SSL config)
DOMAIN=your-domain.example.com

# Full public URLs when behind nginx (used by web container)
# API_URL=https://your-domain.example.com/api
# WS_URL=wss://your-domain.example.com/ws

# ============================================================
# Backup settings (scripts/backup.sh)
# ============================================================
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=7

# ============================================================
# Logging & Runtime
# ============================================================
LOG_LEVEL=info
NODE_ENV=development
