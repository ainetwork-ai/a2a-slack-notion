legacy-peer-deps=true
# Produce a classic flat node_modules layout so Next 16's Turbopack can
# resolve @tiptap/* etc. inside `slack/` without pnpm symlink trickery.
# node-linker=hoisted is the strong form; shamefully-hoist is kept as a
# belt-and-suspenders fallback.
node-linker=hoisted
shamefully-hoist=true
